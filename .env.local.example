NEXT_PUBLIC_SUPABASE_URL=
# Entweder anon JWT (Project Settings → API → anon public) …
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# … oder neuer Publishable Key (sb_publishable_…)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: Skill-Freischaltung + Nutzer-E-Mails (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Kommagetrennte Betreiber-E-Mails (dürfen /einstellungen/betreiber nutzen)
HELPY_OPERATOR_EMAILS=

# Nur lokal für Migrationen (Account → Access Tokens). Nicht committen.
SUPABASE_ACCESS_TOKEN=

# Kontakt für Freischaltung (Pending-Zugang-Seite)
NEXT_PUBLIC_HELPY_SUPPORT_EMAIL=support@helpy.app

# Öffentliche App-URL (Links in E-Mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Wöchentlicher HELPY-Bericht (Gmail + Cron)
CRON_SECRET=

# Microsoft Graph OAuth (Outlook / Microsoft 365) — EINE zentrale HELPY App Registration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/microsoft/callback

# Google OAuth (Gmail / Kalender) — EIN zentrales HELPY Google Cloud Projekt
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Verschlüsselung der OAuth-Tokens in der DB (32+ Zeichen, server-only)
HELPY_OAUTH_ENCRYPTION_KEY=

# Telefonassistent (Phase 3+ — Twilio + OpenAI)
# Speichern der Einstellungen erfordert SUPABASE_SERVICE_ROLE_KEY (siehe oben).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OPENAI_API_KEY=
# Öffentliche Basis-URL für Webhooks (z. B. ngrok / Production)
VOICE_WEBHOOK_BASE_URL=http://localhost:3000

# WhatsApp Business Cloud API (Meta)
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
